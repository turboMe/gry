rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: can only read/write own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Profiles: can only read/write own profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Sessions: can only read/write own sessions
    match /sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // Scenarios: read-only for all authenticated users
    match /scenarios/{scenarioId} {
      allow read: if request.auth != null;
      // Write only from server (Admin SDK bypasses rules)
    }
  }
}
